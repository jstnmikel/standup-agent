{
  "name": "agent-security-scanner",
  "displayName": "Agent Security Scanner",
  "description": "Security scanner for AI agent and MCP developers — covers OWASP Top 10, CWE Top 25, OWASP LLM Top 10, OWASP Agentic Top 10, STRIDE, credential detection, MCP security, and AI transparency patterns.",
  "version": "0.1.3",
  "publisher": "agent-security-scanner",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "scanner": "./dist/cli.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "agentSecurityScanner.runScan",
        "title": "Agent Security Scanner: Run Scan"
      },
      {
        "command": "agentSecurityScanner.runHistoryScan",
        "title": "Agent Security Scanner: Run History Scan"
      },
      {
        "command": "agentSecurityScanner.updateRules",
        "title": "Agent Security Scanner: Update Rules"
      },
      {
        "command": "agentSecurityScanner.viewAuditLog",
        "title": "Agent Security Scanner: View Audit Log"
      },
      {
        "command": "agentSecurityScanner.onboarding",
        "title": "Agent Security Scanner: Onboarding"
      },
      {
        "command": "agentSecurityScanner.selfUpdate",
        "title": "Agent Security Scanner: Self Update"
      },
      {
        "command": "agentSecurityScanner.suppressFinding",
        "title": "Agent Security Scanner: Suppress Finding"
      }
    ],
    "configuration": {
      "title": "Agent Security Scanner",
      "properties": {
        "agentSecurityScanner.debugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging to .kiro/security/scanner-debug.log"
        },
        "agentSecurityScanner.adminPolicyPath": {
          "type": "string",
          "default": ".kiro/security/admin-policy.json",
          "description": "Path to the admin policy file"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node build.js --minify",
    "build:dev": "node build.js --sourcemap",
    "package:exe": "npm run build && pkg dist/cli.js --targets node20-win-x64 --output dist/scanner.exe",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
